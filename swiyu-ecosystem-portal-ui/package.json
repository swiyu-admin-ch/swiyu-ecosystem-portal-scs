{
  "name": "swiyu-ecosystem-portal-ui",
  "version": "1.21.3",
  "private": true,
  "scripts": {
    "build": "ng build --optimization true --output-hashing all --i18n-missing-translation error --i18n-duplicate-translation error",
    "format": "ng lint --fix && stylelint --fix \"src/**/*.scss\" && npm run prettier",
    "pregenerate:api": "rimraf src/app/api/generated",
    "generate:api": "HTTPS_PROXY=\"\" NODE_TLS_REJECT_UNAUTHORIZED='0' openapi-generator-cli generate --generator-key angular-client-api",
    "postgenerate:api": "./node_modules/.bin/prettier --write \"src/app/api/generated/**/*.ts\"",
    "generate:translations": "ngx-translate-extract --sort --input ./src/app --output ./src/assets/i18n/{de,fr,it,en}.json --clean --format json",
    "postgenerate:translations": "./node_modules/.bin/prettier --write \"src/assets/i18n/*.json\"",
    "lint": "ng lint && npm run lint:styles",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "prettier": "prettier --write \"src/**/*.{ts,html,scss,json,js}\"",
    "start": "ng serve",
    "test": "ng test",
    "test:ci": "ng test --watch=false --run-in-band --force-exit --collect-coverage=true",
    "watch": "ng build --watch --configuration development"
  },
  "dependencies": {
    "@angular/animations": "20.3.25",
    "@angular/cdk": "^20.2.10",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/material": "^20.2.10",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/router": "20.3.25",
    "@messageformat/core": "^3.4.0",
    "@ngneat/until-destroy": "^10.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@oblique/oblique": "^14.1.2",
    "@popperjs/core": "^2.0.0",
    "angular-oauth2-oidc": "^20.0.0",
    "ngx-extended-pdf-viewer": "^25.5.1",
    "ngx-translate-messageformat-compiler": "^7.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "^20.0.0",
    "@angular/build": "20.3.25",
    "@angular/cli": "20.3.25",
    "@angular/compiler-cli": "20.3.25",
    "@openapitools/openapi-generator-cli": "^2.31.1",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@vendure/ngx-translate-extract": "^9.4.2",
    "ajv": "^8.0.0",
    "ajv-formats": "^3.0.1",
    "angular-eslint": "20.5.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.6.2",
    "jest-sonar-reporter": "^2.0.0",
    "prettier": "^3.3.3",
    "prettier-eslint": "^16.3.0",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-sort-json": "^4.0.0",
    "rimraf": "^6.0.1",
    "stylelint": "~16.26.1",
    "stylelint-config-prettier-scss": "~1.0.0",
    "stylelint-config-standard-scss": "~13.1.0",
    "stylelint-scss": "~6.14.0",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "shell-quote": "1.9.0"
  },
  "jestSonar": {
    "reportPath": "./coverage/sonarQube",
    "reportFile": "sqr.xml",
    "indent": 4,
    "sonar56x": true
  }
}
