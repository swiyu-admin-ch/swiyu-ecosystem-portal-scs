{
  "name": "swiyu-ecosystem-portal-ui",
  "version": "1.21.12",
  "private": true,
  "scripts": {
    "build": "ng build --optimization true --output-hashing all --i18n-missing-translation error --i18n-duplicate-translation error",
    "format": "ng lint --fix && stylelint --fix \"src/**/*.scss\" && npm run prettier",
    "pregenerate:api": "rimraf src/app/api/generated",
    "generate:api": "HTTPS_PROXY=\"\" NODE_TLS_REJECT_UNAUTHORIZED='0' openapi-generator-cli generate --generator-key angular-client-api",
    "postgenerate:api": "./node_modules/.bin/prettier --write \"src/app/api/generated/**/*.ts\"",
    "generate:translations": "ngx-translate-extract --sort --input ./src/app --output ./src/assets/i18n/{de,fr,it,en}.json --clean --format json",
    "postgenerate:translations": "./node_modules/.bin/prettier --write \"src/assets/i18n/*.json\"",
    "lint": "ng lint && npm run lint:styles",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "prettier": "prettier --write \"src/**/*.{ts,html,scss,json,js}\"",
    "start": "ng serve",
    "test": "ng test",
    "test:ci": "ng test --watch=false --run-in-band --force-exit --collect-coverage=true",
    "watch": "ng build --watch --configuration development"
  },
  "dependencies": {
    "@angular/cdk": "^21.2.14",
    "@angular/common": "21.2.17",
    "@angular/compiler": "21.2.17",
    "@angular/core": "21.2.17",
    "@angular/forms": "21.2.17",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "21.2.17",
    "@angular/platform-browser-dynamic": "21.2.17",
    "@angular/router": "21.2.17",
    "@messageformat/core": "^3.4.0",
    "@ngneat/until-destroy": "^10.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@oblique/oblique": "^15.4.0",
    "@popperjs/core": "^2.11.8",
    "angular-oauth2-oidc": "^20.0.3",
    "js-cookie": "^3.0.8",
    "ngx-extended-pdf-viewer": "^25.6.4",
    "ngx-translate-messageformat-compiler": "^7.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "^21.0.4",
    "@angular/build": "21.2.18",
    "@angular/cli": "21.2.18",
    "@angular/compiler-cli": "21.2.17",
    "@openapitools/openapi-generator-cli": "^2.39.1",
    "@schematics/angular": "^21.2.18",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@vendure/ngx-translate-extract": "^10.2.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "angular-eslint": "21.4.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-preset-angular": "^17.0.0",
    "jest-sonar-reporter": "^2.0.0",
    "prettier": "^3.9.4",
    "prettier-eslint": "^16.4.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "rimraf": "^6.1.3",
    "stylelint": "~16.26.1",
    "stylelint-config-prettier-scss": "~1.0.0",
    "stylelint-config-standard-scss": "~13.1.0",
    "stylelint-scss": "~6.14.0",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "shell-quote": "1.9.0",
    "@angular-devkit/build-angular": "21.2.18",
    "brace-expansion": "5.0.7",
    "esbuild": "0.28.1",
    "vite": "7.3.6"
  },
  "jestSonar": {
    "reportPath": "./coverage/sonarQube",
    "reportFile": "sqr.xml",
    "indent": 4,
    "sonar56x": true
  }
}
